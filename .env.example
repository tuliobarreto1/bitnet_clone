# Cole essas variáveis na tela de Environment Variables do Coolify

# Domínio que o Traefik vai expor
BITNET_DOMAIN=bitnet.seudominio.com

# Modelo (opções: veja README)
HF_REPO=microsoft/BitNet-b1.58-2B-4T-gguf
QUANT_TYPE=i2_s

# Ajuste conforme vCPUs da VM
THREADS=4

# Limite de memória do container
MEMORY_LIMIT=8G

# Opcional: token do Hugging Face (para modelos restritos)
# HUGGING_FACE_HUB_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx
